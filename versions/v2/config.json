{
    "name": "medium_sample_full_agent_modifiers",
    "agent_dir": "",
    "architecture": {
        "d_model": 64,
        "n_heads": 8,
        "n_kv_heads": 2,
        "d_ff": 256,
        "n_encoder_layers": 4,
        "n_decoder_layers": 4,
        "n_value_layers": 2,
        "n_action_layers": 4,
        "max_seq_len": 2048,
        "max_players": 9,
        "memory": {
            "n_levels": 2,
            "max_cluster_size": 128,
            "max_cluster_size_after": 64,
            "beam_width": 8
        }
    },
    "multi_agent": {
        "save_dir": "5_test_agents",
        "agents": [
            {
                "name": "gto_pure",
                "modifiers": [
                    {"type": "temperature", "value": 0.3}
                ]
            },
            {
                "name": "lag_bluffer",
                "modifiers": [
                    {"type": "action_bias", "actions": "aggressive", "factor": 0.35},
                    {"type": "action_bias", "actions": "fold", "factor": -0.25},
                    {"type": "conditional_bias", "condition": "equity < 0.3", "actions": "raises", "factor": 0.4},
                    {"type": "temperature", "value": 0.3}
                ]
            },
            {
                "name": "tight_passive",
                "modifiers": [
                    {"type": "action_bias", "actions": "fold", "factor": 0.3},
                    {"type": "action_bias", "actions": "raises", "factor": -0.2},
                    {"type": "temperature", "value": 0.1}
                ]
            },
            {
                "name": "value_heavy",
                "modifiers": [
                    {"type": "conditional_bias", "condition": "equity > 0.6", "actions": "aggressive", "factor": 0.5},
                    {"type": "conditional_bias", "condition": "equity < 0.4", "actions": "fold", "factor": 0.3},
                    {"type": "temperature", "value": 0.3}
                ]
            },
            {
                "name": "mid_raise_specialist",
                "modifiers": [
                    {"type": "action_bias", "actions": "15:35", "factor": 0.4},
                    {"type": "action_bias", "actions": [0, 1, 52], "factor": -0.15},
                    {"type": "temperature", "value": 0.3}
                ]
            }
        ]
    },
    "game": {
        "table_bins": 50,
        "table_max_bet": 5,
        "max_players": 9,
        "max_stack": 3000,
        "big_blind": 10
    },
    "solver": {
        "type": "v3",
        "mc_iterations": 1000,
        "n_raise_samples": 3,
        "gto_temperature": 0.2,
        "eqr_enabled": true,
        "combo_response_iters": 30,
        "reraise_threshold": 0.75,
        "weighted_sampling": true
    },
    "dataset": {
        "dataset_dir": "",
        "n_scenarios": 700,
        "val_split": 0.1
    },
    "gto_ev_train": {
        "lr": 3e-4,
        "batch_size": 16,
        "epochs": 1,
        "max_grad_norm": 1.0,
        "log_every": 10,
        "val_every": 10,
        "interrupt_after_fails": 20,
        "scheduler_eta_min": 3e-6
    },
    "gto_probs_train": {
        "lr": 3e-4,
        "batch_size": 16,
        "epochs": 1,
        "max_grad_norm": 1.0,
        "log_every": 10,
        "val_every": 10,
        "interrupt_after_fails": 20,
        "scheduler_eta_min": 3e-6
    },
    "evaluation": {
        "agents_dir": "/Users/zer0o0ne/Documents/ContinuousLearning/data/v1/5_test_agents",
        "num_players": 5,
        "n_hands": 10000,
        "big_blind": 10,
        "start_stack": 1500,
        "min_rebuy_stack": 500,
        "max_rebuy_stack": 1500,
        "max_stack_cap": 3000,
        "log_every": 1000,
        "action_temperature": 0.5
    },
    "pipeline": {
        "run_gto_ev": false,
        "run_gto_probs": false,
        "run_evaluation": true
    }
}
